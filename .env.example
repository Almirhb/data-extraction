# ============================================
# .env.example
# Kopjo kete file si ".env" dhe fut vlerat reale.
# .env NUK duhet te shkoje kurre ne git (eshte tashme ne .gitignore)
# ============================================

# --- GitHub API ---
GITHUB_TOKEN=your_github_personal_access_token_here

# --- StackOverflow / Stack Exchange API ---

# Me key grows ne 10,000 req/dite: https://stackapps.com/apps/oauth/register
STACKEXCHANGE_KEY=your_stackexchange_api_key_here

# --- Database paths ---
RAW_STAGING_DB_PATH=data/raw_staging.db
PIPELINE_DB_PATH=data/pipeline.db

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE_PATH=logs/pipeline.log

# --- General ---
# how many days after
TRENDS_TIMEFRAME=today 3-m
